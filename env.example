# =============================================================================
# FlowSync SaaS Revenue Intelligence — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp env.example .env
#
# NEVER commit .env to version control.
# All secrets must be rotated before production deployment.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=flowsync_bi
POSTGRES_USER=flowsync
POSTGRES_PASSWORD=flowsync_secret_change_me

# Full connection URL (overrides individual vars above if set)
# DATABASE_URL=postgresql://flowsync:flowsync_secret_change_me@localhost:5432/flowsync_bi

# Async URL for SQLAlchemy async engine (used by FastAPI)
# ASYNC_DATABASE_URL=postgresql+asyncpg://flowsync:flowsync_secret_change_me@localhost:5432/flowsync_bi

# Connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true

# Retry settings (exponential backoff)
DB_CONNECT_RETRIES=5
DB_CONNECT_RETRY_DELAY=1.0
DB_CONNECT_RETRY_BACKOFF=2.0
DB_CONNECT_RETRY_MAX_DELAY=30.0

# Schema search path (medallion architecture)
DB_SCHEMA_SEARCH_PATH=marts,staging,raw,public

# SSL (set to require for production)
# DB_SSL_MODE=require
# DB_SSL_CERT=/path/to/client.crt
# DB_SSL_KEY=/path/to/client.key
# DB_SSL_ROOT_CERT=/path/to/ca.crt

# -----------------------------------------------------------------------------
# pgAdmin 4 (docker-compose --profile tools)
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=admin@flowsync.dev
PGADMIN_PASSWORD=pgadmin_secret_change_me
PGADMIN_PORT=5050

# -----------------------------------------------------------------------------
# FastAPI Backend
# -----------------------------------------------------------------------------
API_ENV=development
API_PORT=8000
API_PREFIX=/api/v1
SECRET_KEY=dev-secret-key-change-in-production-use-openssl-rand-hex-32
LOG_LEVEL=INFO
ECHO_SQL=false

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=60

# -----------------------------------------------------------------------------
# Next.js Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=FlowSync Revenue Intelligence
NEXT_PUBLIC_APP_VERSION=1.0.0

# Set to "true" to use mock data instead of live API (useful for demo/dev)
NEXT_PUBLIC_USE_MOCK_DATA=true

# Analytics (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# dbt Configuration
# -----------------------------------------------------------------------------
DBT_TARGET=dev
DBT_PROFILES_DIR=./dbt_project

# dbt Cloud (optional — for CI/CD dbt Cloud runs)
# DBT_CLOUD_TOKEN=your_dbt_cloud_token
# DBT_CLOUD_ACCOUNT_ID=12345
# DBT_CLOUD_JOB_ID=67890

# -----------------------------------------------------------------------------
# Data Generation / Seeding
# -----------------------------------------------------------------------------
SEED_ACCOUNTS=300
SEED_MONTHS=24
SEED_RANDOM_SEED=42

# Output directory for generated CSV files
DATA_OUTPUT_DIR=./data/output

# -----------------------------------------------------------------------------
# Deployment — Vercel (Frontend)
# -----------------------------------------------------------------------------
# VERCEL_TOKEN=your_vercel_token
# VERCEL_ORG_ID=your_org_id
# VERCEL_PROJECT_ID=your_project_id

# -----------------------------------------------------------------------------
# Deployment — Render / Railway (Backend + Database)
# -----------------------------------------------------------------------------
# RENDER_API_KEY=your_render_api_key
# RAILWAY_TOKEN=your_railway_token

# Production database URL (set by Render/Railway automatically)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# -----------------------------------------------------------------------------
# GitHub Actions CI/CD
# -----------------------------------------------------------------------------
# These are set as GitHub repository secrets, not in .env:
#   POSTGRES_PASSWORD       → used in CI test matrix
#   SECRET_KEY              → used in API integration tests
#   VERCEL_TOKEN            → used for frontend deployment
#   RENDER_API_KEY          → used for backend deployment
#   DBT_CLOUD_TOKEN         → used for dbt Cloud runs (optional)

# -----------------------------------------------------------------------------
# Monitoring & Observability (optional)
# -----------------------------------------------------------------------------
# SENTRY_DSN=https://xxxx@sentry.io/yyyy
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# OpenTelemetry (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=flowsync-api

# -----------------------------------------------------------------------------
# Email / Notifications (optional)
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your_sendgrid_api_key
# ALERT_EMAIL_FROM=alerts@flowsync.dev
# ALERT_EMAIL_TO=team@flowsync.dev
