# =============================================================================
# FlowSync SaaS Revenue Intelligence — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=flowsync_bi
POSTGRES_USER=flowsync
POSTGRES_PASSWORD=flowsync_secret_change_me
DATABASE_URL=postgresql://flowsync:flowsync_secret_change_me@localhost:5432/flowsync_bi

# -----------------------------------------------------------------------------
# FASTAPI BACKEND
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
# production | development | test
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
API_PREFIX=/api/v1

# -----------------------------------------------------------------------------
# NEXT.JS FRONTEND
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=FlowSync Revenue Intelligence
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_COMPANY_NAME=FlowSync
# Set to 'true' to use mock data instead of live API
NEXT_PUBLIC_USE_MOCK_DATA=false

# -----------------------------------------------------------------------------
# DBT
# -----------------------------------------------------------------------------
DBT_PROFILES_DIR=/app/dbt_project
DBT_TARGET=dev
DBT_THREADS=4

# -----------------------------------------------------------------------------
# DATA GENERATION
# -----------------------------------------------------------------------------
# Number of synthetic accounts to generate
SEED_ACCOUNTS=200
# Number of months of historical data
SEED_MONTHS=24
# Random seed for reproducibility
SEED_RANDOM_SEED=42

# -----------------------------------------------------------------------------
# DEPLOYMENT (Vercel / Render)
# -----------------------------------------------------------------------------
# Vercel
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-vercel-org-id
VERCEL_PROJECT_ID=your-vercel-project-id

# Render
RENDER_API_KEY=your-render-api-key
RENDER_SERVICE_ID=your-render-service-id

# -----------------------------------------------------------------------------
# MONITORING (Optional)
# -----------------------------------------------------------------------------
SENTRY_DSN=
LOG_LEVEL=INFO
